# ============================================
# AI News Bot - Environment Configuration
# ============================================
# This file is for LOCAL DEVELOPMENT ONLY
# For GitHub Actions, use Repository Secrets instead
# Copy this file to .env and fill in your actual values

# ============================================
# LLM Provider Configuration
# ============================================
# Choose your LLM provider: 'claude', 'deepseek', 'gemini', 'grok', or 'openai'
# Note: config.yaml setting takes precedence unless overridden here
LLM_PROVIDER=claude

# Optional: Specify a specific model (leave commented to use provider default)
# Claude models: claude-sonnet-4-5-20250929, claude-3-5-sonnet-20241022
# DeepSeek models: deepseek-chat, deepseek-reasoner
# Gemini models: gemini-2.0-flash-exp, gemini-pro
# Grok models: grok-beta
# OpenAI models: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# LLM_MODEL=claude-sonnet-4-5-20250929

# ============================================
# API Keys (provide the one you're using)
# ============================================
# For Claude/Anthropic (required if using Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# For DeepSeek (required if using DeepSeek)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# For Google Gemini (required if using Gemini)
GOOGLE_API_KEY=your_google_api_key_here

# For xAI Grok (required if using Grok)
XAI_API_KEY=your_xai_api_key_here

# For OpenAI (required if using OpenAI)
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# Email Configuration (Gmail SMTP)
# ============================================
# Get App Password at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here
EMAIL_TO=recipient@example.com

# ============================================
# WhatsApp Configuration (via Twilio)
# ============================================
# Sign up at https://www.twilio.com — free sandbox available
# Sandbox sender: whatsapp:+14155238886 (use your approved number in production)
# Add 'whatsapp' to NOTIFICATION_METHODS to enable
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+1234567890

# ============================================
# Webhook Configuration (Optional)
# ============================================
WEBHOOK_URL=https://your-webhook-url.com/endpoint

# ============================================
# Slack Configuration (Optional)
# ============================================
# Get webhook URL from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# Optional: Override default channel (e.g., #general or @username)
# SLACK_CHANNEL=#general
# Optional: Override bot username
# SLACK_USERNAME=AI News Bot

# ============================================
# Telegram Configuration (Optional)
# ============================================
# Create bot via @BotFather on Telegram to get token
TELEGRAM_AI_BOT_TOKEN=your_bot_token_here
# Chat ID can be user ID, group ID, or channel ID
# Use @userinfobot to get your chat ID
TELEGRAM_AI_CHAT_ID=your_chat_id_here

# ============================================
# Discord Configuration (Optional)
# ============================================
# Create webhook in Discord channel settings
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL
# Optional: Override bot username
# DISCORD_USERNAME=AI News Bot
# Optional: Custom avatar URL
# DISCORD_AVATAR_URL=https://example.com/avatar.png

# ============================================
# Notification Settings
# ============================================
# Comma-separated list of notification methods to enable
# Available: email, webhook, slack, telegram, discord
NOTIFICATION_METHODS=email

# ============================================
# Language Settings
# ============================================
# Language for AI-generated content
# Supported: en, zh, es, fr, ja, de, ko, pt, ru, ar, hi, it, nl
# Single language:
AI_RESPONSE_LANGUAGE=en
# Multiple languages (comma-separated):
# AI_RESPONSE_LANGUAGE=en,zh,ja

# ============================================
# Web Search Settings
# ============================================
# Enable web search to fetch current news (true/false)
# Default: false (disabled - RSS feeds are more reliable)
ENABLE_WEB_SEARCH=false

# ============================================
# Subscription Bot Settings
# ============================================
# Path to the SQLite database storing user channel subscriptions
# Default: data/subscriptions.db
# DB_PATH=data/subscriptions.db

# ============================================
# Scheduler Settings
# ============================================
# Times to send each daily digest (HH:MM, 24-hour format)
# Leave blank to disable that channel's scheduled run
SCHEDULE_ALL_TIME=
SCHEDULE_AI_TIME=
# Optional: day(s) of week for each channel
# Values: daily, monday, tuesday, wednesday, thursday, friday, saturday, sunday
# Comma-separate for multiple days, e.g. monday,thursday
# Leave blank or omit to publish every day (default)
SCHEDULE_AI_DAY=
SCHEDULE_MEDICAL_TIME=
SCHEDULE_PHARMA_TIME=
SCHEDULE_GENOME_TIME=
SCHEDULE_GENETICS_TIME=
SCHEDULE_GENETICS_DAY=
SCHEDULE_ENERGY_TIME=
SCHEDULE_ENERGY_DAY=
SCHEDULE_RARE_EARTH_TIME=
SCHEDULE_PSYCHOLOGY_TIME=
SCHEDULE_SPORTS_TIME=
SCHEDULE_FINANCE_TIME=
SCHEDULE_ENTERTAINMENT_TIME=
SCHEDULE_MUSIC_TIME=

# ============================================
# Specialty Channel Tokens & Chat IDs
# ============================================
TELEGRAM_MEDICAL_BOT_TOKEN=
TELEGRAM_MEDICAL_CHAT_ID=
TELEGRAM_PHARMA_BOT_TOKEN=
TELEGRAM_PHARMA_CHAT_ID=
TELEGRAM_GENOME_BOT_TOKEN=
TELEGRAM_GENOME_CHAT_ID=
TELEGRAM_GENETICS_BOT_TOKEN=
TELEGRAM_GENETICS_CHAT_ID=
TELEGRAM_ENERGY_BOT_TOKEN=
TELEGRAM_ENERGY_CHAT_ID=
TELEGRAM_RARE_EARTH_BOT_TOKEN=
TELEGRAM_RARE_EARTH_CHAT_ID=
TELEGRAM_PSYCHOLOGY_BOT_TOKEN=
TELEGRAM_PSYCHOLOGY_CHAT_ID=
TELEGRAM_SPORTS_BOT_TOKEN=
TELEGRAM_SPORTS_CHAT_ID=
TELEGRAM_FINANCE_BOT_TOKEN=
TELEGRAM_FINANCE_CHAT_ID=
TELEGRAM_ENTERTAINMENT_BOT_TOKEN=
TELEGRAM_ENTERTAINMENT_CHAT_ID=
TELEGRAM_MUSIC_BOT_TOKEN=
TELEGRAM_MUSIC_CHAT_ID=
